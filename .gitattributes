# Normalize line endings: text files are LF in the repo, auto-converted on checkout.
* text=auto eol=lf

# Files that MUST stay LF regardless of platform (break with CRLF).
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files: never touched.
*.png binary
*.jpg binary
*.gif binary
*.pdf binary
