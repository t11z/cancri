# cancri — environment template. Copy to .env.local for the web app (Vite reads VITE_*).
# NEVER commit real values. .env* is gitignored.

# ── web client (apps/web) ───────────────────────────────────────────────────
# In dev these default to the demo project + the local emulator suite, so you can
# run `scripts/dev.sh` with NONE of these set. Fill them for a real Firebase project.
VITE_USE_EMULATOR=true
VITE_EMULATOR_HOST=127.0.0.1
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# ── functions (server-side) ─────────────────────────────────────────────────
# Gemini runs on Vertex AI via service-account IAM — there is NO Gemini API key.
# The deployed config lives in a committed `functions/.env` (non-secret), which
# `firebase deploy --only functions` reads automatically — not here, not GitHub.
# Deployed default is the real model; the emulator and tests use the offline
# parser regardless (FUNCTIONS_EMULATOR pins it). Set CANCRI_USE_VERTEX=false to
# force the parser anywhere. GOOGLE_CLOUD_PROJECT is provided by the runtime.
#   functions/.env → CANCRI_USE_VERTEX, CANCRI_VERTEX_LOCATION, CANCRI_GEMINI_MODEL

# ── feed-engine (Cloud Run; secrets via Secret Manager) ─────────────────────
# L&S handshake config lives in Secret Manager, not in env or the repo:
#   LS_cid, adapter set, origin, idle/polling params (the break surface).

# ── deploy (GitHub repo *Variables*, not secrets) ───────────────────────────
# Set these as repo Variables to enable deploy.yml (CANCRI_DEPLOY_ENABLED=true):
#   GCP_PROJECT_ID   — the Firebase/GCP project id
#   GCP_REGION       — defaults to europe-west1
#   WIF_PROVIDER     — projects/<num>/locations/global/workloadIdentityPools/<pool>/providers/<provider>
#   DEPLOYER_SA      — cancri-deployer@<project>.iam.gserviceaccount.com
