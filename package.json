{
  "name": "cancri",
  "version": "0.0.0",
  "private": true,
  "description": "cancri — live-portfolio-terminal (read-only)",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "pnpm --filter @cancri/web dev",
    "build": "pnpm --filter @cancri/web build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "tokens": "pnpm --filter @cancri/tokens-gen run generate"
  }
}
