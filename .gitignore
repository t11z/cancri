# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
functions/lib/
services/feed-engine/lib/
*.tsbuildinfo

# generated (regenerated from design/ by tools/tokens)
**/src/generated/

# env / secrets — never commit
.env
.env.*
!.env.example
# functions/.env holds only non-secret Vertex config (no Gemini key — IAM, ADR-0008),
# and firebase deploy reads it at deploy time, so it is committed on purpose.
!functions/.env
*.pem
serviceAccount*.json

# firebase / emulator
.firebase/
firebase-debug.log
firestore-debug.log
database-debug.log
ui-debug.log

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
