# Functions runtime env — read automatically by `firebase deploy --only functions`
# (firebase-functions v2 dotenv). These are NOT secrets: Vertex access is via the
# runtime service account's IAM identity, there is no Gemini API key (ADR-0008).
# Committed on purpose (gitignore carves out an exception) so the deployed model
# config is reproducible and reviewable. Secrets, if any, go to Secret Manager.

# Call the real model. The emulator and tests ignore this and use the offline
# parser regardless (see getGeminiClient): FUNCTIONS_EMULATOR pins the mock there.
CANCRI_USE_VERTEX=true
# Vertex serving location for the model — NOT the Function's deploy region
# (that stays europe-west1, ADR-0001). The stable Gemini 3.x models are not
# offered as single-region endpoints in europe-west1; they are served only via
# the `eu` multi-region (traffic stays in the EU geography) or `global`. We pick
# `eu` to keep inference in the EU, consistent with the data-residency posture.
CANCRI_VERTEX_LOCATION=eu
CANCRI_GEMINI_MODEL=gemini-3.5-flash
